# .env.example
# Copy this file to .env and fill in your actual database credentials.
# This file should NOT be committed to version control.

# --- 資料庫（擇一）---
# 未設定 DATABASE_URL 時使用 SQLite；DATABASE_FILE 建議為「本機或 scratch 較快磁碟」上的路徑，
# 避免將 .db 放在高延遲 NFS 上造成鎖與 I/O 瓶頸。
DATABASE_FILE=./resource_accounting.db

# 若使用 PostgreSQL，請先安裝驅動: pip install 'psycopg[binary]>=3.2'
# 再設定完整 URL，例如：
# DATABASE_URL=postgresql+psycop://USER:PASS@localhost:5432/hpc_accounting
# DATABASE_URL=

REDIS_HOST=localhost
REDIS_PORT=6379
# 選用；注意：queries.py 目前未讀此變數，僅 scripts/check_redis.py 自檢可用
# REDIS_PASSWORD=

# 診斷：python scripts/profile_database.py（SQLite）
#        python scripts/check_redis.py（Redis PING / 延遲 / 世代鍵）